{
  "manifest_version": 3,
  "name": "职位猎手 - 自动采集",
  "version": "1.0",
  "description": "浏览Boss直聘/猎聘时自动采集职位信息，一键翻页批量抓取",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://www.liepin.com/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/web/geek/job*", "https://www.zhipin.com/job_detail/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.liepin.com/zhaopin/*", "https://www.liepin.com/job/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "职位猎手"
  }
}
